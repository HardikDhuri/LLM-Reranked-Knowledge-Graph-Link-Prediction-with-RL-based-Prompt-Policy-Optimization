# LLM Provider (OpenAI-compatible)
AI_GATEWAY_API_KEY=your-api-key-here
AI_GATEWAY_BASE_URL=https://ai-gateway.uni-paderborn.de/v1
AI_GATEWAY_MODEL=gpt-4o-mini

# Wikidata SPARQL
WIKIDATA_SPARQL_URL=https://query.wikidata.org/sparql
WIKIDATA_USER_AGENT=kg-llm-rl-link-prediction/1.0

# Directories
DATA_DIR=data_fb15k237
CACHE_DIR=cache
RESULTS_DIR=results

# Reproducibility
RANDOM_SEED=42

# Logging
LOG_LEVEL=INFO

# Evaluation
SAMPLE_TEST_QUERIES=15
NUM_CANDIDATES=25
TOPK_SHOW=5

# RL
RL_REWARD_LAMBDA=0.1
